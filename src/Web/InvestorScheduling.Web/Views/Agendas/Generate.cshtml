
@model InvestorScheduling.Web.Models.GenerarAgendaViewModel

@{
    ViewData["Title"] = "Generar agenda";
}

<h1>Generar agenda</h1>

@if (ViewBag.Error is not null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<form asp-action="Generate" method="post" class="row g-3">
    <div class="col-md-6">
        <label class="form-label">Inversor</label>
        <select asp-for="IdInversor" class="form-select">
            <option value="">Seleccione</option>
            @foreach (var inversor in Model.Inversores)
            {
                <option value="@inversor.Id">@inversor.NombreCompleto - @inversor.EmpresaRepresenta</option>
            }
        </select>
    </div>

    <div class="col-md-6">
        <label asp-for="Fecha" class="form-label">Fecha agenda</label>
        <input asp-for="Fecha" type="date" class="form-control" />
    </div>

    <div class="col-md-6">
        <label asp-for="DuracionReunionMinutos" class="form-label">Duración por reunión</label>
        <input asp-for="DuracionReunionMinutos" class="form-control" />
    </div>

    <div class="col-md-6">
        <label asp-for="CantidadReunionesMeta" class="form-label">Meta de reuniones</label>
        <input asp-for="CantidadReunionesMeta" class="form-control" />
    </div>

    <div class="col-12">
        <label class="form-label">Participantes candidatos</label>
        @foreach (var participante in Model.Participantes)
        {
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="IdsParticipantes" value="@participante.Id" id="p@participante.Id" />
                <label class="form-check-label" for="p@participante.Id">
                    @participante.NombreCompleto - @participante.Institucion - @participante.NombreOficina (@string.Join(", ", participante.CodigosIdioma))
                </label>
            </div>
        }
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-success">Generar</button>
        <a asp-action="Index" class="btn btn-secondary">Volver</a>
    </div>
</form>
