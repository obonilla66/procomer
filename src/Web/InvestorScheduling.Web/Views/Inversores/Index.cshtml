
@model List<InvestorScheduling.Web.Models.InversorResponse>

@{
    ViewData["Title"] = "Inversores";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Inversores</h1>
    <a class="btn btn-primary" asp-action="Create">Nuevo inversor</a>
</div>

<table class="table table-striped">
    <thead>
    <tr>
        <th>Nombre</th>
        <th>Empresa</th>
        <th>País</th>
        <th>Visita</th>
        <th>Idiomas</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.NombreCompleto</td>
            <td>@item.EmpresaRepresenta</td>
            <td>@item.PaisOrigen</td>
            <td>@item.FechaInicioVisita.ToString("dd/MM/yyyy") - @item.FechaFinVisita.ToString("dd/MM/yyyy")</td>
            <td>@string.Join(", ", item.CodigosIdioma)</td>
        </tr>
    }
    </tbody>
</table>
